{
  "env_id": "system_ops.archive_forensics.v1",
  "domain": "system_ops",
  "version": 1,
  "status": "active",
  "tags": [
    "ale-like",
    "archive",
    "forensics",
    "file-state",
    "tool-use"
  ],
  "tool_allowlist": [
    "bin2mcp/busybox-mcp/decompress_file",
    "bin2mcp/busybox-mcp/file_info",
    "bin2mcp/busybox-mcp/checksum",
    "bin2mcp/file-mcp/identify_file",
    "bin2mcp/xxhash-mcp/xxhash_compute",
    "bin2mcp/busybox-mcp/write_file"
  ],
  "entrypoint": {
    "init": "init:create_episode",
    "verifier": "verifier:verify"
  },
  "episode": {
    "max_steps": 8,
    "timeout_secs": 120,
    "workspace_policy": "isolated_tmp"
  },
  "splits": {
    "smoke": "tasks/smoke.json",
    "train": "tasks/smoke.json",
    "dev": "tasks/smoke.json",
    "heldout": "tasks/smoke.json"
  },
  "scoring": {
    "type": "deterministic",
    "max_score": 1.0
  }
}
