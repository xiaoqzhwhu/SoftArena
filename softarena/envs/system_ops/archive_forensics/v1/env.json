{
  "env_id": "system_ops.archive_forensics.v1",
  "domain": "system_ops",
  "version": 1,
  "status": "active",
  "tags": [
    "ale-like",
    "archive",
    "forensics",
    "file-state",
    "tool-use"
  ],
  "tool_allowlist": [
    "utils/tar/tar_extract",
    "utils/tar/tar_list",
    "utils/gzip/gzip_test",
    "utils/file/file_detect",
    "utils/openssl/openssl_hash"
  ],
  "entrypoint": {
    "init": "init:create_episode",
    "verifier": "verifier:verify"
  },
  "episode": {
    "max_steps": 8,
    "timeout_secs": 120,
    "workspace_policy": "isolated_tmp"
  },
  "splits": {
    "smoke": "tasks/smoke.json",
    "train": "tasks/smoke.json",
    "dev": "tasks/smoke.json",
    "heldout": "tasks/smoke.json"
  },
  "scoring": {
    "type": "deterministic",
    "max_score": 1.0
  }
}
