{
  "env_id": "finance.accounting_reconcile.v1",
  "domain": "finance",
  "version": 1,
  "status": "active",
  "tags": [
    "ale-like",
    "finance",
    "accounting",
    "sqlite",
    "reconciliation",
    "tool-use"
  ],
  "tool_allowlist": [
    "cli-db/sqlite3/sqlite_query",
    "cli-db/sqlite3/sqlite_exec",
    "cli-data/csvkit/csv_clean"
  ],
  "entrypoint": {
    "init": "init:create_episode",
    "verifier": "verifier:verify"
  },
  "episode": {
    "max_steps": 10,
    "timeout_secs": 120,
    "workspace_policy": "isolated_tmp"
  },
  "splits": {
    "smoke": "tasks/smoke.json",
    "train": "tasks/smoke.json",
    "dev": "tasks/smoke.json",
    "heldout": "tasks/smoke.json"
  },
  "scoring": {
    "type": "deterministic",
    "max_score": 1.0
  }
}
