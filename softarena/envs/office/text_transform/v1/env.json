{
  "env_id": "office.text_transform.v1",
  "domain": "office",
  "version": 1,
  "status": "active",
  "tags": [
    "ale-like",
    "text",
    "csv",
    "semantic-diff",
    "tool-use"
  ],
  "tool_allowlist": [
    "text/sed/sed",
    "text/awk/awk",
    "devel/jq/jq",
    "cli-data/csvkit/csvcut"
  ],
  "entrypoint": {
    "init": "init:create_episode",
    "verifier": "verifier:verify"
  },
  "episode": {
    "max_steps": 8,
    "timeout_secs": 120,
    "workspace_policy": "isolated_tmp"
  },
  "splits": {
    "smoke": "tasks/smoke.json",
    "train": "tasks/smoke.json",
    "dev": "tasks/smoke.json",
    "heldout": "tasks/smoke.json"
  },
  "scoring": {
    "type": "deterministic",
    "max_score": 1.0
  }
}
