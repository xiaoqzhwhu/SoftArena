{
  "env_id": "software_engineering.sqlite_data_repair.v1",
  "domain": "software_engineering",
  "version": 1,
  "status": "active",
  "tags": [
    "ale-like",
    "database",
    "sqlite",
    "state-verification",
    "tool-use"
  ],
  "tool_allowlist": [
    "bin2mcp/postgresql-client-mcp/sql_execute",
    "bin2mcp/postgresql-client-mcp/sql_describe",
    "bin2mcp/postgresql-client-mcp/sql_list_tables"
  ],
  "entrypoint": {
    "init": "init:create_episode",
    "verifier": "verifier:verify"
  },
  "episode": {
    "max_steps": 8,
    "timeout_secs": 120,
    "workspace_policy": "isolated_tmp"
  },
  "splits": {
    "smoke": "tasks/smoke.json",
    "train": "tasks/smoke.json",
    "dev": "tasks/smoke.json",
    "heldout": "tasks/smoke.json"
  },
  "scoring": {
    "type": "deterministic",
    "max_score": 1.0
  }
}
