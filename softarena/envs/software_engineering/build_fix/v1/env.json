{
  "env_id": "software_engineering.build_fix.v1",
  "domain": "software_engineering",
  "version": 1,
  "status": "active",
  "tags": [
    "ale-like",
    "build",
    "c",
    "hidden-tests",
    "tool-use"
  ],
  "tool_allowlist": [
    "bin2mcp/bmake-mcp/run_build",
    "bin2mcp/bmake-mcp/trace_build",
    "bin2mcp/bmake-mcp/makefile_targets",
    "bin2mcp/clang-mcp/clang_compile",
    "bin2mcp/bear-mcp/run_intercepted_build",
    "bin2mcp/bear-mcp/get_compile_commands",
    "bin2mcp/busybox-mcp/write_file"
  ],
  "entrypoint": {
    "init": "init:create_episode",
    "verifier": "verifier:verify"
  },
  "episode": {
    "max_steps": 10,
    "timeout_secs": 120,
    "workspace_policy": "isolated_tmp"
  },
  "splits": {
    "smoke": "tasks/smoke.json",
    "train": "tasks/smoke.json",
    "dev": "tasks/smoke.json",
    "heldout": "tasks/smoke.json"
  },
  "scoring": {
    "type": "deterministic",
    "max_score": 1.0
  }
}
