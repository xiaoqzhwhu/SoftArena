{
  "env_id": "software_engineering.build_fix.v1",
  "domain": "software_engineering",
  "version": 1,
  "status": "active",
  "tags": [
    "ale-like",
    "build",
    "c",
    "hidden-tests",
    "tool-use"
  ],
  "tool_allowlist": [
    "devel/make/make",
    "devel/gcc/gcc",
    "devel/clang/clang",
    "devel/bear/bear"
  ],
  "entrypoint": {
    "init": "init:create_episode",
    "verifier": "verifier:verify"
  },
  "episode": {
    "max_steps": 10,
    "timeout_secs": 120,
    "workspace_policy": "isolated_tmp"
  },
  "splits": {
    "smoke": "tasks/smoke.json",
    "train": "tasks/smoke.json",
    "dev": "tasks/smoke.json",
    "heldout": "tasks/smoke.json"
  },
  "scoring": {
    "type": "deterministic",
    "max_score": 1.0
  }
}
