{
  "env_id": "network.dns_debug.v1",
  "domain": "network",
  "version": 1,
  "status": "active",
  "tags": [
    "ale-like",
    "network",
    "dns",
    "mocked-service",
    "tool-use"
  ],
  "tool_allowlist": [
    "admin-net/curl/curl_get",
    "admin-net/curl/curl_head_probe",
    "admin-net/curl/curl_ssl_inspect",
    "utils/openssl/openssl_verify_cert",
    "utils/openssl/openssl_hash"
  ],
  "entrypoint": {
    "init": "init:create_episode",
    "verifier": "verifier:verify"
  },
  "episode": {
    "max_steps": 8,
    "timeout_secs": 120,
    "workspace_policy": "isolated_tmp"
  },
  "splits": {
    "smoke": "tasks/smoke.json",
    "train": "tasks/smoke.json",
    "dev": "tasks/smoke.json",
    "heldout": "tasks/smoke.json"
  },
  "scoring": {
    "type": "deterministic",
    "max_score": 1.0
  }
}
